msgid "A PHP version providing random_bytes() is required by Synchro AAD."
msgstr "A PHP version providing random_bytes() is required by Synchro AAD."

msgid "Authentification SSO"
msgstr "SSO authentication"

msgid "Ce compte est désactivé dans GLPI."
msgstr "This account is disabled in GLPI."

msgid "Ce compte ne correspond pas au domaine autorisé pour cette connexion."
msgstr "This account does not match the domain allowed for this connection."

msgid "Client ID"
msgstr "Client ID"

msgid "Client Secret"
msgstr "Client secret"

msgid "Connexion Entra ID"
msgid_plural "Connexions Entra ID"
msgstr[0] "Entra ID connection"
msgstr[1] "Entra ID connections"

msgid "Connexion Entra ID"
msgstr "Entra ID connection"

msgid "Connexion SSO introuvable ou désactivée."
msgstr "SSO connection not found or disabled."

msgid "Connexion GLPI"
msgstr "GLPI login"

msgid "Continuer"
msgstr "Continue"

msgid "Créer les comptes manquants"
msgstr "Create missing accounts"

msgid "Désactiver les comptes absents"
msgstr "Disable missing accounts"

msgid "Entité par défaut (nouveaux comptes)"
msgstr "Default entity (new accounts)"

msgid "Erreur renvoyée par Entra ID : %s"
msgstr "Error returned by Entra ID: %s"

msgid "Ex. : @contoso.com — seuls les comptes dont l'email se termine ainsi sont traités. Plusieurs domaines possibles, séparés par une virgule ou un point-virgule (ex. : @contoso.com, @fabrikam.com)."
msgstr "E.g. @contoso.com — only accounts whose e-mail ends this way are processed. Several domains are allowed, separated by a comma or a semicolon (e.g. @contoso.com, @fabrikam.com)."

msgid "Filtre de domaine"
msgstr "Domain filter"

msgid "Impossible de récupérer le profil utilisateur depuis Microsoft Graph."
msgstr "Unable to retrieve the user profile from Microsoft Graph."

msgid "La connexion à GLPI a échoué (aucune habilitation valide ?)."
msgstr "Logging in to GLPI failed (no valid authorization?)."

msgid "Laisser vide pour utiliser : %s — cette URL doit être déclarée comme \"Redirect URI\" (type Web) dans Entra ID."
msgstr "Leave empty to use: %s — this URL must be declared as a \"Redirect URI\" (Web type) in Entra ID."

msgid "Profil par défaut (nouveaux comptes)"
msgstr "Default profile (new accounts)"

msgid "Requête SSO invalide (state)."
msgstr "Invalid SSO request (state)."

msgid "Retour"
msgstr "Back"

msgid "SSO activé"
msgstr "SSO enabled"

msgid "Se connecter avec %s"
msgstr "Sign in with %s"

msgid "Supprimer les comptes absents"
msgstr "Delete missing accounts"

msgid "Synchro AAD"
msgstr "Synchro AAD"

msgid "Synchronisation"
msgstr "Synchronization"

